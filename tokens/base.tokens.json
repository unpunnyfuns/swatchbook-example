{
  "color": {
    "$type": "color",
    "palette": {
      "neutral": {
        "0": { "$value": { "colorSpace": "srgb", "components": [1, 1, 1] } },
        "900": { "$value": { "colorSpace": "srgb", "components": [0.11, 0.13, 0.15] } }
      },
      "blue": {
        "500": { "$value": { "colorSpace": "srgb", "components": [0.231, 0.51, 0.965] } }
      },
      "green": {
        "500": { "$value": { "colorSpace": "srgb", "components": [0.133, 0.773, 0.369] } }
      }
    },
    "surface": {
      "default": { "$value": "{color.palette.neutral.0}" }
    },
    "text": {
      "default": { "$value": "{color.palette.neutral.900}" }
    },
    "accent": {
      "bg": { "$value": "{color.palette.blue.500}" },
      "fg": { "$value": "{color.palette.neutral.0}" }
    }
  },
  "dimension": {
    "$type": "dimension",
    "space": {
      "md": { "$value": { "value": 12, "unit": "px" } }
    },
    "radius": {
      "sm": { "$value": { "value": 4, "unit": "px" } }
    }
  },
  "typography": {
    "$type": "typography",
    "body": {
      "$value": {
        "fontFamily": "system-ui, sans-serif",
        "fontSize": { "value": 1, "unit": "rem" },
        "fontWeight": 400,
        "lineHeight": 1.5
      }
    }
  },
  "shadow": {
    "$type": "shadow",
    "md": {
      "$value": {
        "color": { "colorSpace": "srgb", "components": [0, 0, 0], "alpha": 0.15 },
        "offsetX": { "value": 0, "unit": "px" },
        "offsetY": { "value": 2, "unit": "px" },
        "blur": { "value": 8, "unit": "px" },
        "spread": { "value": 0, "unit": "px" }
      }
    }
  }
}
